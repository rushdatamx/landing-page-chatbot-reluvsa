---
// ============================================
// PREGUNTAS FRECUENTES - PERSONALIZAR SEGÚN EL NEGOCIO
// ============================================
const faqs = [
  {
    question: "¿Hacen instalación de llantas?",
    answer: "Sí, incluimos montaje, balanceo y válvulas nuevas sin costo adicional en todas nuestras llantas. El servicio tarda aproximadamente 30-45 minutos."
  },
  {
    question: "¿Tienen garantía las llantas?",
    answer: "Todas nuestras llantas cuentan con garantía de fábrica. Además, ofrecemos garantía adicional en instalación. Te entregamos tu póliza por escrito."
  },
  {
    question: "¿Qué formas de pago aceptan?",
    answer: "Aceptamos efectivo, todas las tarjetas de débito y crédito, y transferencias bancarias. Manejamos meses sin intereses con tarjetas participantes."
  },
  {
    question: "¿Cuánto tarda en llegar mi pedido?",
    answer: "Si tenemos la llanta en existencia, puedes pasar el mismo día. Si es pedido especial, generalmente llega en 1-3 días hábiles."
  },
  {
    question: "¿Cómo sé qué medida de llanta necesito?",
    answer: "Puedes revisar el costado de tu llanta actual donde viene la medida (ej: 205/55R16). También puedes enviarnos foto por WhatsApp y te ayudamos."
  },
  {
    question: "¿Ofrecen servicio de alineación y balanceo?",
    answer: "Sí, ofrecemos alineación computarizada y balanceo con pesos de alta calidad. El balanceo está incluido con la compra de llantas."
  },
  {
    question: "¿Tienen promociones o descuentos?",
    answer: "Constantemente tenemos promociones especiales. Escríbenos por WhatsApp para conocer las ofertas vigentes y precios especiales por juego completo."
  },
  {
    question: "¿Puedo apartar mis llantas?",
    answer: "Sí, con un anticipo podemos apartar tus llantas hasta por 7 días. Pregúntanos las condiciones por WhatsApp."
  }
];
---

<section id="faq" class="py-16 md:py-24 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        Preguntas Frecuentes
      </h2>
      <p class="text-xl text-gray-600">
        Resolvemos tus dudas antes de que preguntes
      </p>
    </div>

    <!-- FAQ Accordion -->
    <div class="space-y-4">
      {faqs.map((faq, index) => (
        <details class="group bg-gray-50 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer hover:bg-gray-100 transition-colors">
            <h3 class="text-lg font-semibold text-gray-900 pr-4">
              {faq.question}
            </h3>
            <span class="flex-shrink-0 w-8 h-8 bg-primary-100 rounded-full flex items-center justify-center text-primary-600 group-open:rotate-180 transition-transform duration-300">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </span>
          </summary>
          <div class="px-6 pb-6">
            <p class="text-gray-600 leading-relaxed">
              {faq.answer}
            </p>
          </div>
        </details>
      ))}
    </div>

    <!-- Additional Help -->
    <div class="mt-12 text-center bg-primary-50 rounded-2xl p-8">
      <p class="text-gray-700 mb-4">
        ¿No encontraste lo que buscabas?
      </p>
      <p class="text-lg font-semibold text-primary-700">
        Escríbenos por WhatsApp y te ayudamos con gusto
      </p>
    </div>
  </div>
</section>
