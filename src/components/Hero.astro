---
// ============================================
// CONFIGURACIÓN - RELUVSA AUTOPARTES
// ============================================
const config = {
  phone: "15558712368",
  yearsExperience: "30",
  city: "Cd. Victoria",
};

const whatsappUrl = `https://wa.me/${config.phone}?text=${encodeURIComponent('Hola, quiero comprar llantas')}`;
---

<section class="relative overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0">
    <img
      src="/images/reluvsa-tienda.jpeg"
      alt="Reluvsa Service Center"
      class="w-full h-full object-cover"
    />
    <!-- Overlay oscuro para legibilidad -->
    <div class="absolute inset-0 bg-gradient-to-br from-primary-900/85 via-primary-800/80 to-primary-700/75"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24 lg:py-32">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Content -->
      <div class="text-center lg:text-left">
        <!-- Badge de urgencia -->
        <div class="inline-flex items-center gap-2 bg-green-500/20 backdrop-blur-sm text-white px-4 py-2 rounded-full text-sm font-medium mb-6 border border-green-400/30">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
          </span>
          <span>Compra 100% en línea desde WhatsApp</span>
        </div>

        <!-- Headline -->
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
          Compra tus Llantas
          <span class="text-yellow-400">Sin Salir de Casa</span>
        </h1>

        <!-- Subheadline persuasivo -->
        <p class="text-xl md:text-2xl text-white/90 mb-4 max-w-xl mx-auto lg:mx-0">
          Escríbenos tu medida por WhatsApp y recibe tu cotización
          <span class="font-semibold text-yellow-400">en segundos</span>.
        </p>

        <!-- Propuesta de valor -->
        <p class="text-lg text-white/80 mb-8 max-w-xl mx-auto lg:mx-0">
          Paga en línea con tarjeta y te llevamos tus llantas.
          <span class="font-semibold">Así de fácil.</span>
        </p>

        <!-- CTA Principal -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start mb-8">
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center justify-center gap-3 bg-whatsapp hover:bg-whatsapp-hover text-white font-bold px-8 py-5 rounded-full text-xl transition-all duration-300 hover:scale-105 shadow-2xl hover:shadow-green-500/40"
          >
            <svg class="w-7 h-7 transition-transform group-hover:scale-110" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Comprar Ahora
          </a>
        </div>

        <!-- Micro-copy de confianza -->
        <p class="text-sm text-white/60 mb-8">
          Respuesta automática 24/7 • Sin esperas • Sin llamadas
        </p>

        <!-- Trust Badges -->
        <div class="flex flex-wrap justify-center lg:justify-start gap-4 text-white/80">
          <div class="flex items-center gap-2 bg-white/10 backdrop-blur-sm px-3 py-2 rounded-lg">
            <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm font-medium">Pago seguro con tarjeta</span>
          </div>
          <div class="flex items-center gap-2 bg-white/10 backdrop-blur-sm px-3 py-2 rounded-lg">
            <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm font-medium">Envío a domicilio</span>
          </div>
          <div class="flex items-center gap-2 bg-white/10 backdrop-blur-sm px-3 py-2 rounded-lg">
            <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm font-medium">+30 años de experiencia</span>
          </div>
        </div>
      </div>

      <!-- Hero Visual - Proceso simplificado -->
      <div class="relative hidden lg:block">
        <div class="relative w-full max-w-md mx-auto">
          <!-- Card principal: Simulación de chat -->
          <div class="bg-white rounded-2xl shadow-2xl p-6 transform rotate-1 hover:rotate-0 transition-transform duration-300">
            <div class="flex items-center gap-3 mb-4 pb-4 border-b">
              <div class="w-12 h-12 bg-whatsapp rounded-full flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </div>
              <div>
                <p class="font-bold text-gray-900">Reluvsa Autopartes</p>
                <p class="text-xs text-green-600 flex items-center gap-1">
                  <span class="w-2 h-2 bg-green-500 rounded-full"></span>
                  En línea ahora
                </p>
              </div>
            </div>

            <!-- Chat messages -->
            <div class="space-y-3">
              <div class="flex justify-end">
                <div class="bg-green-100 text-gray-800 px-4 py-2 rounded-2xl rounded-tr-md text-sm max-w-[80%]">
                  Hola, busco llantas 205/55R16
                </div>
              </div>
              <div class="flex justify-start">
                <div class="bg-gray-100 text-gray-800 px-4 py-2 rounded-2xl rounded-tl-md text-sm max-w-[80%]">
                  ¡Tenemos disponibles! NEREUS a $1,299 c/u. ¿Te envío link de pago?
                </div>
              </div>
              <div class="flex justify-end">
                <div class="bg-green-100 text-gray-800 px-4 py-2 rounded-2xl rounded-tr-md text-sm max-w-[80%]">
                  ¡Sí, por favor!
                </div>
              </div>
            </div>

            <!-- Typing indicator -->
            <div class="mt-3 flex items-center gap-2 text-gray-500 text-sm">
              <div class="flex gap-1">
                <span class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 0ms;"></span>
                <span class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 150ms;"></span>
                <span class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 300ms;"></span>
              </div>
              <span>Enviando link de pago...</span>
            </div>
          </div>

          <!-- Floating badges -->
          <div class="absolute -top-4 -right-4 bg-yellow-400 text-yellow-900 rounded-full px-4 py-2 font-bold text-sm shadow-lg animate-bounce" style="animation-duration: 2s;">
            Respuesta instantánea
          </div>

          <div class="absolute -bottom-4 -left-4 bg-white rounded-lg shadow-xl p-3">
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2V6h10a2 2 0 00-2-2H4zm2 6a2 2 0 012-2h8a2 2 0 012 2v4a2 2 0 01-2 2H8a2 2 0 01-2-2v-4zm6 4a2 2 0 100-4 2 2 0 000 4z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs text-gray-500">Pago seguro</p>
                <p class="font-bold text-gray-900 text-sm">Stripe</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Wave separator -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
      <path d="M0 120L60 110C120 100 240 80 360 70C480 60 600 60 720 65C840 70 960 80 1080 85C1200 90 1320 90 1380 90L1440 90V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="white"/>
    </svg>
  </div>
</section>
