---
// ============================================
// CONFIGURACIÓN - RELUVSA AUTOPARTES
// ============================================

// Testimonios inventados para Reluvsa
const testimonials = [
  {
    name: "Jorge Hernández",
    vehicle: "Ford F-150 2023",
    rating: 5,
    text: "Llevo más de 10 años comprando mis llantas en Reluvsa. Siempre me dan el mejor precio y la atención es de primera. Las llantas Tornel que me pusieron han aguantado muy bien los caminos de terracería.",
    avatar: null
  },
  {
    name: "Patricia Rodríguez",
    vehicle: "Nissan Versa 2022",
    rating: 5,
    text: "Me encanta que puedo cotizar por WhatsApp y me responden súper rápido. La instalación fue muy profesional y el precio mucho mejor que en otras refaccionarias de Victoria. 100% recomendados.",
    avatar: null
  },
  {
    name: "Miguel Ángel Torres",
    vehicle: "Chevrolet Silverado 2021",
    rating: 5,
    text: "Reluvsa tiene más de 30 años en el mercado y eso se nota en la calidad del servicio. Me asesoraron muy bien sobre las llantas Nereus para mi camioneta. Excelente relación calidad-precio.",
    avatar: null
  }
];
---

<section id="testimonios" class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        Lo que dicen nuestros clientes
      </h2>
      <p class="text-xl text-gray-600">
        Miles de conductores ya confían en nosotros
      </p>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid md:grid-cols-3 gap-8">
      {testimonials.map((testimonial) => (
        <div class="bg-white rounded-2xl p-6 shadow-sm hover:shadow-lg transition-all duration-300">
          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            {Array(testimonial.rating).fill(0).map(() => (
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <p class="text-gray-700 mb-6 leading-relaxed">
            "{testimonial.text}"
          </p>

          <!-- Author -->
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-primary-100 rounded-full flex items-center justify-center">
              {testimonial.avatar ? (
                <img src={testimonial.avatar} alt={testimonial.name} class="w-full h-full rounded-full object-cover" />
              ) : (
                <span class="text-primary-600 font-semibold text-lg">
                  {testimonial.name.split(' ').map(n => n[0]).join('')}
                </span>
              )}
            </div>
            <div>
              <p class="font-semibold text-gray-900">{testimonial.name}</p>
              <p class="text-sm text-gray-500">{testimonial.vehicle}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Trust Badge -->
    <div class="mt-12 text-center">
      <div class="inline-flex items-center gap-3 bg-white rounded-full px-6 py-3 shadow-md">
        <svg class="w-6 h-6 text-primary-500" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
        <span class="text-gray-700">
          <span class="font-semibold">+30 años</span> de experiencia en Cd. Victoria
        </span>
      </div>
    </div>
  </div>
</section>
