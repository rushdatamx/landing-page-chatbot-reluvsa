---
// ============================================
// CONFIGURACIÓN - RELUVSA AUTOPARTES
// ============================================
const config = {
  phone: "15558712368",
};

const whatsappUrl = `https://wa.me/${config.phone}?text=${encodeURIComponent('Hola, quiero cotizar llantas para mi vehículo')}`;

const steps = [
  {
    number: "1",
    title: "Escríbenos por WhatsApp",
    description: "Cuéntanos qué vehículo tienes y qué tipo de llanta buscas. Te respondemos en minutos.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
    </svg>`
  },
  {
    number: "2",
    title: "Recibe tu cotización",
    description: "Te enviamos opciones personalizadas según tu presupuesto y necesidades. Sin compromiso.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
    </svg>`
  },
  {
    number: "3",
    title: "Agenda y listo",
    description: "Elige tu horario, llega a nuestro local y en menos de 1 hora sales con llantas nuevas.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>`
  }
];
---

<section id="proceso" class="py-16 md:py-24 bg-primary-900 relative overflow-hidden">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.4&quot;%3E%3Ccircle cx=&quot;30&quot; cy=&quot;30&quot; r=&quot;4&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Cotizar es muy fácil
      </h2>
      <p class="text-xl text-white/80 max-w-2xl mx-auto">
        En 3 simples pasos tienes tus llantas nuevas instaladas
      </p>
    </div>

    <!-- Steps -->
    <div class="grid md:grid-cols-3 gap-8 mb-12">
      {steps.map((step, index) => (
        <div class="relative">
          {/* Connector line (hidden on mobile and last item) */}
          {index < steps.length - 1 && (
            <div class="hidden md:block absolute top-12 left-1/2 w-full h-0.5 bg-white/20">
              <div class="absolute right-0 top-1/2 -translate-y-1/2 w-3 h-3 border-t-2 border-r-2 border-white/40 rotate-45"></div>
            </div>
          )}

          <div class="relative bg-white/10 backdrop-blur-sm rounded-2xl p-8 text-center hover:bg-white/15 transition-all duration-300">
            {/* Step number */}
            <div class="w-16 h-16 mx-auto bg-whatsapp text-white rounded-full flex items-center justify-center text-2xl font-bold mb-6 shadow-lg">
              {step.number}
            </div>

            {/* Icon */}
            <div class="w-14 h-14 mx-auto bg-white/10 rounded-xl flex items-center justify-center text-white mb-4">
              <Fragment set:html={step.icon} />
            </div>

            {/* Content */}
            <h3 class="text-xl font-semibold text-white mb-3">
              {step.title}
            </h3>
            <p class="text-white/70">
              {step.description}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center">
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-whatsapp hover:bg-whatsapp-hover text-white font-bold px-10 py-5 rounded-full text-xl transition-all duration-300 hover:scale-105 shadow-2xl hover:shadow-green-500/30"
      >
        <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Comenzar Ahora
      </a>
      <p class="mt-4 text-white/60 text-sm">
        Sin compromiso. Te respondemos en minutos.
      </p>
    </div>
  </div>
</section>
